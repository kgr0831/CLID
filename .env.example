# ─── CLID backend selection ───────────────────────────────────────────────
# "mock"  → deterministic offline backend (default; runs with no GPU/servers)
# "openai" → OpenAI-compatible HTTP backend (llama.cpp server / TabbyAPI)
CLID_BACKEND=mock

# ─── Orchestrator endpoint (Phase A: classify/design/delegate/diagnose/judge)
# Qwen3.6-35B-A3B · Q4 · ~20-22GB · served by llama.cpp --port 8080
CLID_ORCH_BASE_URL=http://127.0.0.1:8080/v1
CLID_ORCH_MODEL=qwen3.6-35b-a3b-q4
CLID_ORCH_API_KEY=sk-local

# ─── Coder endpoint (Phase B: generation) ─────────────────────────────────
# Scenario A: Qwen3-Coder-30B-A3B  |  Scenario B: DeepSeek-Coder-V2-Lite-16B
# In sequential-swap mode the Coder reuses the SAME port after the swap.
CLID_CODER_BASE_URL=http://127.0.0.1:8080/v1
CLID_CODER_MODEL=qwen3-coder-30b-a3b-q4_k_m
CLID_CODER_API_KEY=sk-local

# ─── Sandbox ───────────────────────────────────────────────────────────────
# "local"  → run build/test in a subprocess (fast, less isolated)
# "docker" → run inside a mounted-workspace container (recommended)
CLID_SANDBOX=local
